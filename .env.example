# Groq API Key (used for listing text generation via Llama 3.3)
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_key_here

# Gemini API Key (used for vision / image analysis)
# Get a key at https://console.cloud.google.com
GEMINI_API_KEY=your_key_here

# Supabase project URL (safe to expose to the browser if needed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (server-side only; never expose in client code)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
